{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "0.2.0.itisyan.patch2",
  "name": "HTSL Reborn (Patched)",
  "description": "Fabric mod that makes programming in Hypixel Housing easier.\n\nPatch2:\n- Fix OR condition in export.\n- Fix color+placeholder in import issue\n- Import time optimization and others bug fix",
  "authors": [
    "Wekend",
    "Sin_ender"
  ],
  "contact": {
    "homepage": "https://redstone.llc/",
    "sources": "https://github.com/redstone-llc/${id}",
    "issues": "https://github.com/redstone-llc/${id}/issues"
  },
  "license": "LGPL-3.0",
  "icon": "assets/htslreborn/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "llc.redstone.htslreborn.HTSLReborn"
      }
    ]
  },
  "mixins": [
    "htslreborn.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader}",
    "minecraft": "${minecraft}",
    "fabric-api": ">=${fabric_api}",
    "fabric-language-kotlin": ">=${fabric_language_kotlin}",
    "systemsapi": ">=${systemsapi}",
    "owo-lib": ">=${owo_lib}"
  }
}